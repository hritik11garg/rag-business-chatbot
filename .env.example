ENV=development
SECRET_KEY=YOUR_SECRET_KEY
DATABASE_URL=postgresql://user:password@localhost:5433/project

# ---- Logging ----
# LOG_LEVEL=INFO

# SECRET_KEY must be a real random value — placeholders are rejected at
# startup, and production requires >=32 chars. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ---- Auth tokens ----
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Rate limiting (per client IP) ----
# Set RATE_LIMIT_ENABLED=false for load testing (see benchmarks/)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_AUTH=10/minute
# RATE_LIMIT_CHAT=30/minute
# Trusted reverse-proxy hops in front of the app. 0 = directly exposed
# (ignore X-Forwarded-For). Set to your real hop count (e.g. 1 behind one
# nginx/ALB) so limits key on the client IP, not the proxy's.
# TRUSTED_PROXY_COUNT=0

# ---- Uploads & transport security ----
# MAX_UPLOAD_MB=25
# Abuse controls: total documents per tenant, and the cap on how many
# chunks one upload may spawn FAQ LLM calls for (bounds cost amplification)
# MAX_DOCUMENTS_PER_ORG=1000
# MAX_FAQ_CHUNKS=50
# RATE_LIMIT_UPLOAD=5/minute
# Enable HSTS only when served over TLS (behind a TLS-terminating proxy)
# ENABLE_HSTS=false

# ---- Infrastructure credentials (docker-compose) ----
# Compose falls back to the dev defaults below if these are unset, and
# publishes Postgres/Redis on 127.0.0.1 only. ALWAYS set real values for
# any deployment — an unauthenticated Redis is a remote-code-execution
# primitive, not just a data leak.
# POSTGRES_USER=raguser
# POSTGRES_PASSWORD=ragpass
# POSTGRES_DB=ragdb
# REDIS_PASSWORD=ragredispass

# ---- Background jobs (Celery) ----
# Defaults match the docker-compose Redis (which now requires a password;
# include it in the URL as redis://:<password>@host:6379/0)
# CELERY_BROKER_URL=redis://:ragredispass@localhost:6379/0
# CELERY_RESULT_BACKEND=redis://:ragredispass@localhost:6379/0

# ---- LLM provider ----
# One of: openai | groq | gemini | ollama | anthropic
LLM_PROVIDER=openai

# Only the key matching LLM_PROVIDER is required (ollama needs none)
OPENAI_API_KEY=sk-xxxxxxx
# GROQ_API_KEY=gsk_xxxxxxx
# GEMINI_API_KEY=AIzaxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxx

# Optional overrides — sensible per-provider defaults apply if unset
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=512

# ---- Retrieval ----
# DEFAULT_TOP_K=5
# MAX_TOP_K=20
# Cross-encoder reranking: retrieve RERANK_CANDIDATES by dense similarity,
# reorder by a query-passage relevance model, keep top_k. Off by default;
# measured +8.3pp Recall@1 on the eval set (see evals/README.md). Enabling
# it loads a ~80 MB model at startup.
# RERANK_ENABLED=false
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANK_CANDIDATES=20
# Hybrid retrieval: fuse dense vectors with a Postgres full-text (keyword)
# ranking via Reciprocal Rank Fusion. Recovers exact-term matches (proper
# nouns, IDs) dense search blurs; composes with reranking. Measured to
# raise the recall ceiling on the eval set (see evals/README.md).
# HYBRID_ENABLED=false
