ENV=development
SECRET_KEY=YOUR_SECRET_KEY
DATABASE_URL=postgresql://user:password@localhost:5433/project

# ---- Logging ----
# LOG_LEVEL=INFO

# ---- Auth tokens ----
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Rate limiting (per client IP) ----
# Set RATE_LIMIT_ENABLED=false for load testing (see benchmarks/)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_AUTH=10/minute
# RATE_LIMIT_CHAT=30/minute

# ---- Background jobs (Celery) ----
# Defaults match the docker-compose Redis; override in other environments
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---- LLM provider ----
# One of: openai | groq | gemini | ollama | anthropic
LLM_PROVIDER=openai

# Only the key matching LLM_PROVIDER is required (ollama needs none)
OPENAI_API_KEY=sk-xxxxxxx
# GROQ_API_KEY=gsk_xxxxxxx
# GEMINI_API_KEY=AIzaxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxx

# Optional overrides — sensible per-provider defaults apply if unset
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=
# LLM_TEMPERATURE=0.1
