ENV=development
SECRET_KEY=YOUR_SECRET_KEY
DATABASE_URL=postgresql://user:password@localhost:5433/project

# ---- LLM provider ----
# One of: openai | groq | gemini | ollama | anthropic
LLM_PROVIDER=openai

# Only the key matching LLM_PROVIDER is required (ollama needs none)
OPENAI_API_KEY=sk-xxxxxxx
# GROQ_API_KEY=gsk_xxxxxxx
# GEMINI_API_KEY=AIzaxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxx

# Optional overrides — sensible per-provider defaults apply if unset
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=
# LLM_TEMPERATURE=0.1
